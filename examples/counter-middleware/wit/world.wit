package wasmcp:counter-middleware@0.1.0;

/// counter-middleware MCP server middleware component
///
/// This component implements the server-middleware pattern, handling tools/list and tools/call
/// methods and delegating all other requests to the downstream handler.
world counter-middleware {
    include wasmcp:mcp-v20251125/server-middleware@0.1.0;

    import wasmcp:mcp-v20251125/sessions@0.1.0;
    import wasmcp:mcp-v20251125/server-io@0.1.0;
}
