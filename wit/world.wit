package wasmcp:mcp@0.3.1-alpha.2;

/// Middleware world for request interception.
///
/// Both imports and exports the handler interface, enabling components
/// to intercept requests before forwarding to the next handler.
@since(version = 0.3.0)
world middleware {
    import incoming-handler;
    export incoming-handler;
}

// A WIT framework for composing Model Context Protocol servers as WebAssembly components.
//
// <https://modelcontextprotocol.io/specification/2025-06-18/schema>
world tools-handler {
    include middleware;
    import list-tools-result;
    import content-tool-result;
    import structured-tool-result;
}

world resources-handler {
    include middleware;
    import list-resources-result;
    import read-resource-result;
    import list-resource-templates-result;
}

world prompts-handler {
    include middleware;
    import list-prompts-result;
    import get-prompt-result;
}

world completions-handler {
    include middleware;
    import complete-result;
}

world lifecycle-handler {
    export incoming-handler;
    import initialize-result;
    import notification-result;
}
