use wasi:io/streams@0.2.3;

interface message-formatter {
    fmt: func(message: string) -> string;
}

interface notifications-writer {
    use streams.{output-stream, stream-error};
    use protocol.{progress-token, log-level, log-message, client-notification, change-notification-type, update-notification-type};

    /// Log a message to the client.
    @since(version = 0.3.1-alpha.1)
    log: func(out: borrow<output-stream>, message: log-message) -> result<_, stream-error>;

    // Send a JSON-RPC notification to the client.
    @since(version = 0.3.1-alpha.1)
    notify: func(out: borrow<output-stream>, notification: client-notification) -> result<_, stream-error>;

    /// Send a `notifications/*/list_changed` notification to the client.
    notify-list-changed: func(out: borrow<output-stream>, change: change-notification-type) -> result<_, stream-error>;

    /// Send a `notifications/*/updated` notification to the client.
    notify-updated: func(out: borrow<output-stream>, update: update-notification-type) -> result<_, stream-error>;

    /// Send a `notifications/progress` notification to the client.
    ///
    /// <https://modelcontextprotocol.io/specification/2025-03-26/basic/utilities/progress>
    notify-progress: func(
        out: borrow<output-stream>,
        progress-token: progress-token,
        progress: f64,
        total: option<f64>,
        message: option<string>,
    ) -> result<_, stream-error>;
}

/// Write a JSON-RPC error response to an output stream.
///
/// This interface provides a standardized way to write error responses
/// that conform to the JSON-RPC 2.0 specification.
///
/// See: <https://spec.json-rpc.org/specification>
@since(version = 0.3.0)
interface error-writer {
    use streams.{output-stream, stream-error};
    use protocol.{id, error};

    write-error: func(
        out: output-stream,
        error: error,
    ) -> result<_, stream-error>;
}

/// Writes initialization results to an output stream.
///
/// <https://modelcontextprotocol.io/specification/2025-06-18/schema#initialize>
@since(version = 0.3.0)
interface lifecycle-writer {
    use streams.{output-stream, stream-error};
    use protocol.{id, initialize-result};

    @since(version = 0.3.0)
    write-initialization: func(out: output-stream, id: id, %result: initialize-result) -> result<_, stream-error>;

    write-pong: func(out: output-stream, id: id) -> result<_, stream-error>;
}

interface tools-writer {
    use streams.{output-stream, stream-error};
    use protocol.{content-block, id, tool, meta, next-cursor-options, structured-tool-result};

    @since(version = 0.3.0)
    record content-blocks-result-options {
        is-error: bool,
        meta: meta,
    }

    write-tools: func(
        out: output-stream,
        id: id,
        tools: list<tool>,
    ) -> result<_, stream-error>;

    write-text: func(
        out: output-stream,
        id: id,
        text: string,
    ) -> result<_, stream-error>;

    write-error: func(
        out: output-stream,
        id: id,
        reason: string
    ) -> result<_, stream-error>;

    write-content-blocks: func(
        out: output-stream,
        id: id,
        content: list<content-block>,
    ) -> result<_, stream-error>;

    write-structured: func(
        out: output-stream,
        id: id,
        structured: structured-tool-result,
    ) -> result<_, stream-error>;

    resource tools-writer {
        start: static func(out: output-stream, id: id) -> result<tools-writer, stream-error>;
        write: func(tool: tool) -> result<_, stream-error>;
        finish: static func(this: tools-writer, options: option<next-cursor-options>) -> result<_, stream-error>;
    }

    resource content-blocks-writer {
        start: static func(out: output-stream, id: id, initial: content-block) -> result<content-blocks-writer, stream-error>;
        write: func(contents: list<u8>) -> result<_, stream-error>;
        next: func(content: content-block) -> result<_, stream-error>;
        finish: static func(this: content-blocks-writer, options: option<content-blocks-result-options>) -> result<_, stream-error>;
    }
}

interface resources-writer {
    use streams.{output-stream, stream-error};
    use protocol.{id, %resource, resource-contents, resource-template, meta-options, next-cursor-options};

    write-resources: func(
        out: output-stream,
        id: id,
        resources: list<%resource>,
    ) -> result<_, stream-error>;

    write-contents: func(
        out: output-stream,
        id: id,
        contents: resource-contents,
    ) -> result<_, stream-error>;

    write-templates: func(
        out: output-stream,
        id: id,
        templates: list<resource-template>,
    ) -> result<_, stream-error>;

    resource resources-writer {
        start: static func(out: output-stream, id: id) -> result<resources-writer, stream-error>;
        write: func(%resource: %resource) -> result<_, stream-error>;
        finish: static func(this: resources-writer, options: option<next-cursor-options>) -> result<_, stream-error>;
    }

    resource contents-writer {
        start: static func(out: output-stream, id: id, initial: resource-contents) -> result<contents-writer, stream-error>;
        write: func(contents: list<u8>) -> result<_, stream-error>;
        finish: static func(this: contents-writer, options: option<meta-options>) -> result<_, stream-error>;
    }

    resource templates-writer {
        start: static func(out: output-stream, id: id) -> result<templates-writer, stream-error>;
        write: func(template: resource-template) -> result<_, stream-error>;
        finish: static func(this: templates-writer, options: option<next-cursor-options>) -> result<_, stream-error>;
    }
}

interface prompts-writer {
    use streams.{output-stream, stream-error};
    use protocol.{description-options, id, prompt, prompt-message, next-cursor-options};

    write-prompts: func(
        out: output-stream,
        id: id,
        prompts: list<prompt>,
    ) -> result<_, stream-error>;

    write-prompt-messages: func(
        out: output-stream,
        id: id,
        messages: list<prompt-message>,
    ) -> result<_, stream-error>;

    resource prompts-writer {
        start: static func(out: output-stream, id: id) -> result<prompts-writer, stream-error>;
        write: func(prompt: prompt) -> result<_, stream-error>;
        finish: static func(this: prompts-writer, options: option<next-cursor-options>) -> result<_, stream-error>;
    }

    resource prompt-messages-writer {
        start: static func(out: output-stream, id: id) -> result<prompt-messages-writer, stream-error>;
        write: func(message: prompt-message) -> result<_, stream-error>;
        finish: static func(this: prompt-messages-writer, options: option<description-options>) -> result<_, stream-error>;
    }
}

/// Writes completion/complete results to an output stream.
///
/// The response structure follows MCP schema with a nested "completion" object
/// containing "values", "total", and "hasMore" fields.
///
/// <https://modelcontextprotocol.io/specification/2025-06-18/schema#completion-complete>
@since(version = 0.3.0)
interface completions-writer {
    use streams.{output-stream, stream-error};
    use protocol.{id};

    /// Options for completion results, matching MCP schema.
    /// Used to provide additional metadata about completion results.
    @since(version = 0.3.0)
    record completion-result-options {
        /// The total number of completion options available.
        /// This can exceed the number of values actually sent in the response.
        total: option<u64>,
        /// Indicates whether there are additional completion options beyond
        /// those provided in the current response.
        has-more: option<bool>,
    }

    record completions {
        values: list<string>,
        options: option<completion-result-options>,
    }

    /// Send a complete list of completion values in one call.
    /// The implementation will output the proper nested MCP structure:
    write-completions: func(
        out: output-stream,
        id: id,
        completions: completions,
    ) -> result<_, stream-error>;

    /// Streaming writer for sending completion values incrementally.
    resource completions-writer {
        start: static func(out: output-stream,id: id) -> result<completions-writer, stream-error>;
        write: func(value: string) -> result<_, stream-error>;
        finish: static func(this: completions-writer, options: option<completion-result-options>) -> result<_, stream-error>;
    }
}
