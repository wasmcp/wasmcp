interface message-context {
    use protocol.{mcp-message, server-capability};

    variant parse-error {
        /// Raw JSON parse/utf8 failure
        invalid-json(string),
        /// Well-formed JSON but not valid JSON-RPC
        invalid-jsonrpc(string),
        /// JSON-RPC but violates MCP shape/fields
        schema(string),
        other(string),
    }

    resource message-context {
        /// Parse a JSON-RPC 2.0 object from bytes.
        @since(version = 0.3.1-alpha.2)
        from-bytes: static func(bytes: list<u8>) -> result<message-context, parse-error>;

        message: func() -> mcp-message;

        /// Get a context value by key.
        @since(version = 0.3.0)
        get: func(key: string) -> option<string>;

        /// Set a context value by key.
        @since(version = 0.3.0)
        set: func(key: string, value: string);

        register-capability: func(capability: server-capability);
    }
}
