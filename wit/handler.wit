/// Handler interface for incoming MCP requests.
///
/// This interface defines the contract for handling MCP requests
/// and writing responses to an output stream.
@since(version = 0.3.0)
interface incoming-handler {
    use wasi:io/streams@0.2.3.{output-stream};
    use request.{request};

    /// Handle an incoming MCP request and write the response to the output stream.
    /// The handler receives ownership of the request resource, allowing it to
    /// either process the request or forward it to the next handler in the chain.
    @since(version = 0.3.0)
    handle: func(request: request, output: output-stream);
}

/// Lifecycle management interface for MCP requests.
@since(version = 0.3.1-alpha.1)
interface lifecycle-handler {
    use wasi:io/streams@0.2.3.{output-stream};
    use request.{request, initialize-params};

    /// https://modelcontextprotocol.io/specification/2025-06-18/schema#initialize
    @since(version = 0.3.1-alpha.1)
    initialize: func(req: borrow<request>, output: borrow<output-stream>, params: initialize-params) -> result;

    /// https://modelcontextprotocol.io/specification/2025-06-18/schema#ping
    @since(version = 0.3.1-alpha.1)
    ping: func(req: borrow<request>, output: borrow<output-stream>) -> result;

    /// https://modelcontextprotocol.io/specification/2025-06-18/schema#notifications%2Finitialized
    @since(version = 0.3.1-alpha.1)
    notifications-initialized: func(req: borrow<request>, output: borrow<output-stream>) -> result;
}

/// Handle tools methods
@since(version = 0.3.1-alpha.1)
interface tools-handler {
    use wasi:io/streams@0.2.3.{output-stream};
    use request.{request, list-tools-params, call-tool-params};

    /// https://modelcontextprotocol.io/specification/2025-06-18/schema#tools%2Flist
    @since(version = 0.3.1-alpha.1)
    list-tools: func(req: borrow<request>, output: borrow<output-stream>, params: list-tools-params) -> result;

    /// https://modelcontextprotocol.io/specification/2025-06-18/schema#tools%2Fcall
    @since(version = 0.3.1-alpha.1)
    call-tool: func(req: borrow<request>, output: borrow<output-stream>, params: call-tool-params) -> result;
}

/// Handle resources methods
@since(version = 0.3.1-alpha.1)
interface resources-handler {
    use wasi:io/streams@0.2.3.{output-stream};
    use request.{request, list-resources-params, read-resource-params, list-resource-templates-params};

    /// https://modelcontextprotocol.io/specification/2025-06-18/schema#resources%2Flist
    @since(version = 0.3.1-alpha.1)
    list-resources: func(req: borrow<request>, output: borrow<output-stream>, params: list-resources-params) -> result;
 
    /// https://modelcontextprotocol.io/specification/2025-06-18/schema#resources%2Fread
    @since(version = 0.3.1-alpha.1)
    read-resource: func(req: borrow<request>, output: borrow<output-stream>, params: read-resource-params) -> result;

    /// https://modelcontextprotocol.io/specification/2025-06-18/schema#resources%2Ftemplates%2Flist
    @since(version = 0.3.1-alpha.1)
    list-resource-templates: func(req: borrow<request>, output: borrow<output-stream>, params: list-resource-templates-params) -> result;
}

/// Handle prompts methods
@since(version = 0.3.1-alpha.1)
interface prompts-handler {
    use wasi:io/streams@0.2.3.{output-stream};
    use request.{request, list-prompts-params, get-prompt-params};

    /// https://modelcontextprotocol.io/specification/2025-06-18/schema#prompts%2Flist
    @since(version = 0.3.1-alpha.1)
    list-prompts: func(req: borrow<request>, output: borrow<output-stream>, params: list-prompts-params) -> result;

    /// https://modelcontextprotocol.io/specification/2025-06-18/schema#prompts%2Fget
    @since(version = 0.3.1-alpha.1)
    get-prompt: func(req: borrow<request>, output: borrow<output-stream>, params: get-prompt-params) -> result;
}

/// Handle completions methods
@since(version = 0.3.1-alpha.1)
interface completions-handler {
    use wasi:io/streams@0.2.3.{output-stream};
    use request.{request, completion-params};

    /// https://modelcontextprotocol.io/specification/2025-06-18/schema#completion%2Fcomplete
    @since(version = 0.3.1-alpha.1)
    complete: func(req: borrow<request>, output: borrow<output-stream>, params: completion-params) -> result;
}
