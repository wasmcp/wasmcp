interface protocol {
    type json = string;
    type uri = string;
    type cursor = option<string>;
    type meta = option<list<tuple<string, string>>>;

    /// https://modelcontextprotocol.io/specification/2025-06-18/server/utilities/logging#log-levels
    @since(version = 0.3.1-alpha.1)
    enum log-level {
        /// Detailed debugging information
        debug,
        /// General informational messages
        info,
        /// Normal but significant events
        notice,
        /// Warning conditions
        warning,
        /// Error conditions
        error,
        /// Critical conditions
        critical,
        /// Action must be taken immediately
        alert,
        /// System is unusable
        emergency,
    }

    enum change-notification-type {
        tools,
        resources,
        prompts,
    }

    variant update-notification-type {
        %resource(string),
    }

    /// https://modelcontextprotocol.io/specification/2025-06-18/schema#loggingmessagenotification
    @since(version = 0.3.1-alpha.1)
    record log-message {
        level: log-level,
        logger: option<string>,
        data: list<u8>,
    }

    record client-notification {
        method: string,
        params: option<string>,
    }

    /// Standard JSON-RPC error codes.
    @since(version = 0.3.0)
    enum error-code {
        /// Parse error (-32700)
        parse-error,
        /// Invalid request (-32600)
        invalid-request,
        /// Method not found (-32601)
        method-not-found,
        /// Invalid parameters (-32602)
        invalid-params,
        /// Internal error (-32603)
        internal-error,
    }

    /// Progress tokens MUST be a string or integer value.
    ///
    /// <https://modelcontextprotocol.io/specification/2025-03-26/basic/utilities/progress#progress-flow>
    variant progress-token {
        %string(string),
        integer(s64),
    }

    /// JSON-RPC request ID (string or number).
    /// <https://modelcontextprotocol.io/specification/2025-06-18/schema#requestid>
    @since(version = 0.3.0)
    variant id {
        number(s64),
        %string(string),
    }

    /// MCP protocol versions.
    @since(version = 0.3.0)
    enum protocol-version {
        /// Version 2025-06-18
        v20250618,
        /// Version 2025-03-26
        v20250326,
        /// Version 2024-11-05
        v20241105,
    }

    record list-changed-capability-option {
        list-changed: option<bool>,
    }

    record resources-list-changed-capability-option {
        list-changed: option<bool>,
        subscribe: option<bool>,
    }

    record server-capabilities {
        completions: option<json>,
        experimental: option<list<tuple<string, json>>>,
        logging: option<json>,
        prompts: option<list-changed-capability-option>,
        resources: option<resources-list-changed-capability-option>,
        tools: option<list-changed-capability-option>,
    }

    flags tools-capability-options {
        list-changed,
    }

    flags resources-capability-options {
        list-changed,
        subscribe,
    }

    flags prompts-capability-options {
        list-changed,
    }

    variant server-capability {
        completions(option<json>),
        experimental(option<list<tuple<string, json>>>),
        logging(option<json>),
        prompts(prompts-capability-options),
        resources(resources-capability-options),
        tools(tools-capability-options),
    }

    record client-capabilities {
        elicitation: option<json>,
        experimental: option<list<tuple<string, json>>>,
        roots: option<list-changed-capability-option>,
        sampling: option<json>,
    }

    /// MCP implementation metadata.
    /// <https://modelcontextprotocol.io/specification/2025-06-18/schema#implementation>
    @since(version = 0.3.0)
    record implementation {
        name: string,
        title: option<string>,
        version: string,
    }

    /// Role in a conversation.
    ///
    /// Maps to the Role type in the MCP spec:
    /// "The sender or recipient of messages and data in a conversation."
    /// Valid values: "user" | "assistant"
    ///
    /// See: <https://modelcontextprotocol.io/specification/2025-06-18/schema#role>
    @since(version = 0.3.0)
    enum role {
        user,
        assistant,
    }

    /// Optional annotations for the client.
    ///
    /// The client can use annotations to inform how objects are used or displayed.
    /// <https://modelcontextprotocol.io/specification/2025-06-18/schema#annotations>
    @since(version = 0.3.0)
    record annotations {
        /// Describes who the intended customer of this object or data is.
        ///
        /// It can include multiple entries to indicate content useful for multiple audiences (e.g., [“user”, “assistant”]).
        audience: option<list<role>>,

        /// The moment the resource was last modified, as an ISO 8601 formatted string.
        ///
        /// Should be an ISO 8601 formatted string (e.g., “2025-01-12T15:00:58Z”).
        ///
        /// Examples: last activity timestamp in an open file, timestamp when the resource was attached, etc.
        last-modified: option<string>,

        /// Describes how important this data is for operating the server.
        ///
        /// A value of 1 means “most important,” and indicates that the data is effectively required, while 0 means “least important,” and indicates that the data is entirely optional.
        priority: f64,
    }

    /// Options for content blocks.
    @since(version = 0.3.0)
    record content-options {
        /// Optional annotations for the client.
        annotations: option<annotations>,
        /// Optional metadata.
        ///
        /// See: <https://modelcontextprotocol.io/specification/2025-06-18/basic/index#meta>
        meta: meta,
    }
    
    /// Text provided to or from an LLM.
    ///
    /// See: <https://modelcontextprotocol.io/specification/2025-06-18/schema#textcontent>
    @since(version = 0.3.0)
    record text-content {
        /// The text content of the message.
        text: string,
        options: option<content-options>,
    }

    /// An image provided to or from an LLM.
    ///
    /// See: <https://modelcontextprotocol.io/specification/2025-06-18/schema#imagecontent>
    @since(version = 0.3.0)
    record image-content {
        /// The base64-encoded image data.
        data: list<u8>,
        /// The MIME type of the image. Different providers may support different image types.
        mime-type: string,
        options: option<content-options>,
    }

    /// Audio provided to or from an LLM.
    ///
    /// See: <https://modelcontextprotocol.io/specification/2025-06-18/schema#audiocontent>
    @since(version = 0.3.0)
    record audio-content {
        /// The base64-encoded audio data.
        data: list<u8>,
        /// The MIME type of the audio. Different providers may support different audio types.
        mime-type: string,
        options: option<content-options>,
    }

    /// Options for resource link content.
    @since(version = 0.3.0)
    record resource-link-content-options {
        title: option<string>,
        description: option<string>,
        size: option<u64>,
        mime-type: option<string>,
        /// Optional annotations for the client.
        annotations: option<annotations>,
        /// Optional metadata.
        ///
        /// See: <https://modelcontextprotocol.io/specification/2025-06-18/basic/index#meta>
        meta: meta,
    }
    
    /// A resource that the server is capable of reading, included in a prompt or tool call result.
    ///
    /// Note: resource links returned by tools are not guaranteed to appear in the results of resources/list requests.
    ///
    /// See: <https://modelcontextprotocol.io/specification/2025-06-18/schema#resourcelink>
    @since(version = 0.3.0)
    record resource-link-content {
        /// The URI of this resource.
        uri: uri,
        /// Intended for programmatic or logical use, but used as a display name in past specs or fallback (if title isn’t present).
        name: string,
        options: option<resource-link-content-options>,
    }

    /// Options for embedded resources.
    @since(version = 0.3.0)
    record embedded-resource-options {
        mime-type: option<string>,
        meta: meta,
    }

    /// Text resource contents.
    /// <https://modelcontextprotocol.io/specification/2025-06-18/schema#textresourcecontents>
    @since(version = 0.3.0)
    record text-resource-contents {
        uri: uri,
        text: string,
        options: option<embedded-resource-options>,
    }

    /// Binary resource contents.
    /// <https://modelcontextprotocol.io/specification/2025-06-18/schema#blobresourcecontents>
    @since(version = 0.3.0)
    record blob-resource-contents {
        uri: uri,
        blob: list<u8>,
        options: option<embedded-resource-options>,
    }

    /// Embedded resource data.
    @since(version = 0.3.0)
    variant embedded-resource {
        text(text-resource-contents),
        blob(blob-resource-contents),
    }

    /// Embedded resource with content options.
    /// <https://modelcontextprotocol.io/specification/2025-06-18/schema#embeddedresource>
    @since(version = 0.3.0)
    record embedded-resource-content {
        %resource: embedded-resource,
        options: option<content-options>,
    }

    /// Content blocks that can be included in messages.
    ///
    /// See: <https://modelcontextprotocol.io/specification/2025-06-18/schema#contentblock>
    @since(version = 0.3.0)
    variant content-block {
        text(text-content),
        image(image-content),
        audio(audio-content),
        resource-link(resource-link-content),
        embedded-resource(embedded-resource-content),
    }

    /// Options for initialization results.
    @since(version = 0.3.0)
    record initialize-result-options {
        instructions: option<string>,
        meta: meta,
    }

    /// Initialization result structure.
    /// <https://modelcontextprotocol.io/specification/2025-06-18/schema#initializeresult>
    @since(version = 0.3.0)
    record initialize-result {
        server-info: implementation,
        capabilities: server-capabilities,
        protocol-version: protocol-version,
        options: option<initialize-result-options>,
    }

    /// Annotations for tool capabilities.
    /// <https://modelcontextprotocol.io/specification/2025-06-18/schema#toolannotations>
    @since(version = 0.3.0)
    record tool-annotations {
        title: option<string>,
        read-only-hint: option<bool>,
        destructive-hint: option<bool>,
        idempotent-hint: option<bool>,
        open-world-hint: option<bool>,
    }

    /// Optional properties for tool definitions.
    @since(version = 0.3.0)
    record tool-options {
        meta: meta,
        annotations: option<tool-annotations>,
        description: option<string>,
        output-schema: option<json>,
        title: option<string>,
    }

    /// Options for list-tools results.
    @since(version = 0.3.0)
    record next-cursor-options {
        meta: meta,
        next-cursor: cursor,
    }

    /// Tool definition.
    /// <https://modelcontextprotocol.io/specification/2025-06-18/schema#tool>
    @since(version = 0.3.0)
    record tool {
        name: string,
        input-schema: string,
        options: option<tool-options>,
    }

    record structured-tool-result {
        structured-content: json,
        is-error: bool,
        meta: meta,
    }

    @since(version = 0.3.0)
    record resource-options {
        size: option<u64>,
        title: option<string>,
        description: option<string>,
        mime-type: option<string>,
        annotations: option<annotations>,
        meta: meta,
    }

    /// <https://modelcontextprotocol.io/specification/2025-06-18/schema#resource>
    @since(version = 0.3.0)
    record %resource {
        uri: uri,
        name: string,
        options: option<resource-options>,
    }

    @since(version = 0.3.0)
    record resource-contents-options {
        mime-type: option<string>,
        meta: meta,
    }

    @since(version = 0.3.0)
    record resource-contents {
        uri: uri,
        data: list<u8>,
        options: option<resource-contents-options>,
    }

    @since(version = 0.3.0)
    record meta-options {
        meta: meta,
    }

    @since(version = 0.3.0)
    record resource-template-options {
        description: option<string>,
        title: option<string>,
        mime-type: option<string>,
        annotations: option<annotations>,
        meta: meta,
    }

    /// <https://modelcontextprotocol.io/specification/2025-06-18/schema#resourcetemplate>
    @since(version = 0.3.0)
    record resource-template {
        uri-template: string,
        name: string,
        options: option<resource-template-options>,
    }

    /// <https://modelcontextprotocol.io/specification/2025-06-18/schema#promptargument>
    @since(version = 0.3.0)
    record prompt-argument {
        name: string,
        description: option<string>,
        required: option<bool>,
        title: option<string>,
    }

    @since(version = 0.3.0)
    record prompt-options {
        meta: meta,
        arguments: option<list<prompt-argument>>,
        description: option<string>,
        title: option<string>,
    }

    /// <https://modelcontextprotocol.io/specification/2025-06-18/schema#prompt>
    @since(version = 0.3.0)
    record prompt {
        name: string,
        options: option<prompt-options>,
    }

    /// <https://modelcontextprotocol.io/specification/2025-06-18/schema#promptmessage>
    @since(version = 0.3.0)
    record prompt-message {
        content: content-block,
        role: role,
    }

    @since(version = 0.3.0)
    record description-options {
        meta: meta,
        description: option<string>,
    }

    @since(version = 0.3.1-alpha.1)
    enum string-schema-format {
        uri,
        email,
        date,
        date-time,
    }

    /// https://modelcontextprotocol.io/specification/2025-06-18/schema#stringschema
    @since(version = 0.3.1-alpha.1)
    record string-schema {
        description: option<string>,
        format: option<string-schema-format>,
        max-length: option<u32>,
        min-length: option<u32>,
        title: option<string>,
    }

    @since(version = 0.3.1-alpha.1)
    enum number-schema-type {
        number,
        integer,
    }

    /// https://modelcontextprotocol.io/specification/2025-06-18/schema#numberschema
    @since(version = 0.3.1-alpha.1)
    record number-schema {
        description: option<string>,
        maximum: option<f64>,
        minimum: option<f64>,
        title: option<string>,
        %type: number-schema-type,
    }

    /// https://modelcontextprotocol.io/specification/2025-06-18/schema#booleanschema
    @since(version = 0.3.1-alpha.1)
    record boolean-schema {
        default: option<bool>,
        description: option<string>,
        title: option<string>,
    }

    /// https://modelcontextprotocol.io/specification/2025-06-18/schema#enumschema
    @since(version = 0.3.1-alpha.1)
    record enum-schema {
        description: option<string>,
        %enum: list<string>,
        enum-names: option<list<string>>,
        title: option<string>,
    }

    @since(version = 0.3.1-alpha.1)
    variant primitive-schema-definition {
        string-schema(string-schema),
        number-schema(number-schema),
        boolean-schema(boolean-schema),
        enum-schema(enum-schema),
    }

    @since(version = 0.3.1-alpha.1)
    record requested-schema {
        properties: list<tuple<string, primitive-schema-definition>>,
        required: option<list<string>>,
    }

    /// https://modelcontextprotocol.io/specification/2025-06-18/schema#elicitrequest
    @since(version = 0.3.1-alpha.1)
    record elicit-request {
        message: string,
        requested-schema: requested-schema,
    }

    /// Initialize request parameters.
    /// <https://modelcontextprotocol.io/specification/2025-06-18/schema#initializerequest>
    @since(version = 0.3.0)
    record initialize-params {
        capabilities: client-capabilities,
        client-info: implementation,
        protocol-version: protocol-version,
    }

    /// Argument for completion requests.
    @since(version = 0.3.0)
    record completion-argument {
        name: string,
        value: string,
    }

    /// Context for completion requests.
    @since(version = 0.3.0)
    record completion-context {
        arguments: option<string>
    }

    /// Reference to a prompt for completion.
    @since(version = 0.3.0)
    record completion-prompt-reference {
        name: string,
        title: option<string>,
    }

    /// Reference types for completions.
    @since(version = 0.3.0)
    variant completion-ref {
        /// Prompt reference.
        /// <https://modelcontextprotocol.io/specification/2025-06-18/schema#promptreference>
        prompt(completion-prompt-reference),

        /// Resource template reference.
        /// <https://modelcontextprotocol.io/specification/2025-06-18/schema#resourcetemplatereference>
        resource-template(string),
    }

    /// Parameters for completion requests.
    @since(version = 0.3.0)
    record complete-params {
        argument: completion-argument,
        ref: completion-ref,
        context: option<completion-context>,
    }

    /// <https://modelcontextprotocol.io/specification/2025-06-18/schema#calltoolrequest>
    /// https://modelcontextprotocol.io/specification/2025-06-18/schema#getpromptrequest
    @since(version = 0.3.1-alpha.1)
    record arg-params {
        name: string,
        arguments: option<json>,
    }

    @since(version = 0.3.1-alpha.1)
    enum elicit-result-action {
        accept,
        decline,
        cancel,
    }

    @since(version = 0.3.1-alpha.1)
    variant elicit-result-content {
        %string(string),
        number(f64),
        boolean(bool),
    }

    /// https://modelcontextprotocol.io/specification/2025-06-18/schema#elicitresult
    @since(version = 0.3.1-alpha.1)
    record elicit-result {
        meta: meta,
        action: elicit-result-action,
        content: option<list<tuple<string, elicit-result-content>>>,
    }

    /// Cancellation notification.
    ///
    /// https://modelcontextprotocol.io/specification/2025-03-26/basic/utilities/cancellation
    @since(version = 0.3.1-alpha.3)
    record cancellation {
        request-id: id,
        reason: option<string>,
    }

    type tools-list-params = cursor;
    type tools-call-params = arg-params;

    type resources-list-params = cursor;
    type resources-read-params = uri;
    type resources-templates-list-params = cursor;

    type prompts-list-params = cursor;
    type prompts-get-params = arg-params;

    /// Parameters for different MCP methods.
    @since(version = 0.3.0)
    variant request-method {
        /// initialize
        /// <https://modelcontextprotocol.io/specification/2025-06-18/schema#initializerequest>
        initialize(initialize-params),

        /// tools/list
        tools-list(tools-list-params),

        /// tools/call
        /// <https://modelcontextprotocol.io/specification/2025-06-18/schema#calltoolrequest>
        tools-call(tools-call-params),

        /// resources/list
        resources-list(resources-list-params),

        /// resources/read
        resources-read(resources-read-params),

        /// resources/templates/list
        resources-templates-list(resources-templates-list-params),

        /// prompts/list
        prompts-list(prompts-list-params),

        /// prompts/get
        /// <https://modelcontextprotocol.io/specification/2025-06-18/schema#getpromptrequest>
        prompts-get(prompts-get-params),

        /// completion/complete
        completion-complete(complete-params),

        ping,
    }

    variant notification-method {
        /// Cancellation notification
        ///
        /// https://modelcontextprotocol.io/specification/2025-03-26/basic/utilities/cancellation
        cancellation(cancellation),
        progress(progress-token),
        initialized,
        roots-list-changed,
    }

    variant response-result {
        /// Client response to elicitations/create
        /// <https://modelcontextprotocol.io/specification/2025-06-18/client/elicitation#creating-elicitation-requests>
        elicit-result(elicit-result),
    }

    /// Bidirectional error message.
    record mcp-error {
        id: option<id>,
        code: error-code,
        message: string,
        data: option<json>,
    }

    record mcp-request {
        id: id,
        method: request-method,
        progress-token: option<progress-token>,
    }

    record mcp-notification {
        method: notification-method,
    }

    record mcp-result {
        id: id,
        %result: response-result,
    }

    variant mcp-message {
        request(mcp-request),
        notification(mcp-notification),
        %result(mcp-result),
        error(mcp-error),
    }
}
