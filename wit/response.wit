use wasi:io/streams@0.2.3;

interface output {
    use streams.{input-stream, stream-error};
    variant io-error {
        /// The message has not been started yet.
        message-not-started,
        /// A message is currently in progress.
        message-in-progress,
        /// The message has been finished.
        message-finished,
        /// An I/O error occurred.
        %stream(stream-error),
    }

    start-message: func() -> result<_, io-error>;
    write-message-contents: func(contents: list<u8>) -> result<_, io-error>;
    finish-message: func() -> result<_, io-error>;
}

interface notification-response {
    use output.{io-error};
    use protocol.{progress-token, log-level, log-message, client-notification, change-notification-type, update-notification-type};

    /// Log a message to the client.
    @since(version = 0.3.1-alpha.1)
    log: func(message: log-message) -> result<_, io-error>;

    // Send a JSON-RPC notification to the client.
    @since(version = 0.3.1-alpha.1)
    notify: func(notification: client-notification) -> result<_, io-error>;

    /// Send a `notifications/*/list_changed` notification to the client.
    notify-list-changed: func(change: change-notification-type) -> result<_, io-error>;

    /// Send a `notifications/*/updated` notification to the client.
    notify-updated: func(update: update-notification-type) -> result<_, io-error>;

    /// Send a `notifications/progress` notification to the client.
    ///
    /// <https://modelcontextprotocol.io/specification/2025-03-26/basic/utilities/progress>
    notify-progress: func(
        progress-token: progress-token,
        progress: f64,
        total: option<f64>,
        message: option<string>,
    ) -> result<_, io-error>;
}

/// Write a JSON-RPC error response to an output stream.
///
/// This interface provides a standardized way to write error responses
/// that conform to the JSON-RPC 2.0 specification.
///
/// See: <https://spec.json-rpc.org/specification>
@since(version = 0.3.0)
interface error-response {
    use output.{io-error};
    use protocol.{id, mcp-error};

    write: func(
        error: mcp-error,
    ) -> result<_, io-error>;
}

/// Writes initialization results to an output stream.
///
/// <https://modelcontextprotocol.io/specification/2025-06-18/schema#initialize>
@since(version = 0.3.0)
interface lifecycle-response {
    use output.{io-error};
    use protocol.{id, initialize-result};

    @since(version = 0.3.0)
    write-initialization: func(id: id, %result: initialize-result) -> result<_, io-error>;

    write-pong: func(id: id) -> result<_, io-error>;
}

interface tools-response {
    use streams.{input-stream};
    use output.{io-error};
    use protocol.{content-block, id, json, tool, meta, next-cursor-options, structured-tool-result};

    @since(version = 0.3.0)
    record content-blocks-result-options {
        is-error: bool,
        meta: meta,
        structured-content: option<json>,
    }

    write-tools: func(
        id: id,
        tools: list<tool>,
    ) -> result<_, io-error>;

    write-text: func(
        id: id,
        text: string,
    ) -> result<_, io-error>;

    write-error: func(
        id: id,
        reason: string
    ) -> result<_, io-error>;

    write-content-blocks: func(
        id: id,
        content: list<content-block>,
    ) -> result<_, io-error>;

    write-structured: func(
        id: id,
        structured: structured-tool-result,
    ) -> result<_, io-error>;

    resource tools-writer {
        start: static func(id: id) -> result<tools-writer, io-error>;
        write: func(tool: tool) -> result<_, io-error>;
        finish: static func(this: tools-writer, options: option<next-cursor-options>) -> result<_, io-error>;
    }

    /// Stream-first writer for tool call content blocks.
    ///
    /// Enables bounded-memory streaming of arbitrarily large binary content (images, audio)
    /// while maintaining valid JSON throughout. Each `add-*` method writes a complete
    /// content block to the output stream.
    ///
    /// Architecture:
    /// - Small content: Handler provides complete data, protocol serializes
    /// - Large content: Handler provides input-stream, protocol reads + base64-encodes incrementally
    /// - Memory bounded: ~10KB for streaming regardless of content size
    ///
    /// Usage:
    /// ```
    /// let writer = content-blocks-writer::start(id)?;
    /// writer.add-text("Result: ")?;
    /// writer.add-image-stream("image/png", image_stream)?;  // 100MB image, 10KB memory
    /// writer.finish(options)?;
    /// ```
    resource content-blocks-writer {
        /// Start writing tool call content blocks.
        /// Writes JSON-RPC response header and opens content array.
        start: static func(id: id) -> result<content-blocks-writer, io-error>;

        /// Add a text content block.
        add-text: func(text: string) -> result<_, io-error>;

        /// Add an image content block with complete data.
        /// Use for small images where handler has all data in memory.
        add-image: func(data: list<u8>, mime-type: string) -> result<_, io-error>;

        /// Add an image content block by streaming from input-stream.
        /// Enables bounded-memory streaming of large images (e.g., 100MB with 10KB memory).
        /// Protocol reads chunks and base64-encodes incrementally.
        /// Returns number of bytes read from stream.
        add-image-stream: func(mime-type: string, source: borrow<input-stream>) -> result<u64, io-error>;

        /// Add an audio content block with complete data.
        add-audio: func(data: list<u8>, mime-type: string) -> result<_, io-error>;

        /// Add an audio content block by streaming from input-stream.
        /// Returns number of bytes read from stream.
        add-audio-stream: func(mime-type: string, source: borrow<input-stream>) -> result<u64, io-error>;

        /// Add a resource link content block.
        add-resource-link: func(uri: string, name: string) -> result<_, io-error>;

        /// Add an embedded resource content block with text content.
        add-embedded-resource-text: func(uri: string, text: string, mime-type: option<string>) -> result<_, io-error>;

        /// Add an embedded resource content block with complete blob data.
        /// Use for small blobs where handler has all data in memory.
        add-embedded-resource-blob: func(uri: string, blob: list<u8>, mime-type: option<string>) -> result<_, io-error>;

        /// Add an embedded resource content block by streaming blob from input-stream.
        /// Enables bounded-memory streaming of large embedded resource blobs.
        /// Returns number of bytes read from stream.
        add-embedded-resource-blob-stream: func(uri: string, mime-type: option<string>, source: borrow<input-stream>) -> result<u64, io-error>;

        /// Finish writing content blocks and close the response.
        finish: static func(this: content-blocks-writer, options: option<content-blocks-result-options>) -> result<_, io-error>;
    }
}

interface resources-response {
    use streams.{input-stream};
    use output.{io-error};
    use protocol.{id, %resource, resource-contents, resource-template, meta-options, next-cursor-options};

    write-resources: func(
        id: id,
        resources: list<%resource>,
    ) -> result<_, io-error>;

    write-contents: func(
        id: id,
        contents: resource-contents,
    ) -> result<_, io-error>;

    write-templates: func(
        id: id,
        templates: list<resource-template>,
    ) -> result<_, io-error>;

    resource resources-writer {
        start: static func(id: id) -> result<resources-writer, io-error>;
        write: func(%resource: %resource) -> result<_, io-error>;
        finish: static func(this: resources-writer, options: option<next-cursor-options>) -> result<_, io-error>;
    }

    /// Stream-first writer for resource contents.
    ///
    /// Enables bounded-memory streaming of large resource blobs while maintaining
    /// valid JSON. Each `add-*` method writes a complete resource contents object.
    ///
    /// Usage:
    /// ```
    /// let writer = contents-writer::start(id)?;
    /// writer.add-blob-stream("file:///large.bin", "application/octet-stream", blob_stream)?;
    /// writer.finish(options)?;
    /// ```
    resource contents-writer {
        /// Start writing resource contents.
        /// Writes JSON-RPC response header and opens contents array.
        start: static func(id: id) -> result<contents-writer, io-error>;

        /// Add resource contents with text data.
        add-text: func(uri: string, text: string, mime-type: option<string>) -> result<_, io-error>;

        /// Add resource contents with complete blob data.
        /// Use for small blobs where handler has all data in memory.
        add-blob: func(uri: string, data: list<u8>, mime-type: option<string>) -> result<_, io-error>;

        /// Add resource contents by streaming blob from input-stream.
        /// Enables bounded-memory streaming of large resource files.
        /// Protocol reads chunks and base64-encodes incrementally.
        /// Returns number of bytes read from stream.
        add-blob-stream: func(uri: string, mime-type: option<string>, source: borrow<input-stream>) -> result<u64, io-error>;

        /// Finish writing resource contents and close the response.
        finish: static func(this: contents-writer, options: option<meta-options>) -> result<_, io-error>;
    }

    resource templates-writer {
        start: static func(id: id) -> result<templates-writer, io-error>;
        write: func(template: resource-template) -> result<_, io-error>;
        finish: static func(this: templates-writer, options: option<next-cursor-options>) -> result<_, io-error>;
    }
}

interface prompts-response {
    use output.{io-error};
    use protocol.{description-options, id, prompt, prompt-message, next-cursor-options};

    write-prompts: func(
        id: id,
        prompts: list<prompt>,
    ) -> result<_, io-error>;

    write-prompt-messages: func(
        id: id,
        messages: list<prompt-message>,
    ) -> result<_, io-error>;

    resource prompts-writer {
        start: static func(id: id) -> result<prompts-writer, io-error>;
        write: func(prompt: prompt) -> result<_, io-error>;
        finish: static func(this: prompts-writer, options: option<next-cursor-options>) -> result<_, io-error>;
    }

    resource prompt-messages-writer {
        start: static func(id: id) -> result<prompt-messages-writer, io-error>;
        write: func(message: prompt-message) -> result<_, io-error>;
        finish: static func(this: prompt-messages-writer, options: option<description-options>) -> result<_, io-error>;
    }
}

/// Writes completion/complete results to an output stream.
///
/// The response structure follows MCP schema with a nested "completion" object
/// containing "values", "total", and "hasMore" fields.
///
/// <https://modelcontextprotocol.io/specification/2025-06-18/schema#completion-complete>
@since(version = 0.3.0)
interface completions-response {
    use output.{io-error};
    use protocol.{id};

    /// Options for completion results, matching MCP schema.
    /// Used to provide additional metadata about completion results.
    @since(version = 0.3.0)
    record completion-result-options {
        /// The total number of completion options available.
        /// This can exceed the number of values actually sent in the response.
        total: option<u64>,
        /// Indicates whether there are additional completion options beyond
        /// those provided in the current response.
        has-more: option<bool>,
    }

    record completions {
        values: list<string>,
        options: option<completion-result-options>,
    }

    /// Send a complete list of completion values in one call.
    /// The implementation will output the proper nested MCP structure:
    write-completions: func(
        id: id,
        completions: completions,
    ) -> result<_, io-error>;

    /// Streaming writer for sending completion values incrementally.
    resource completions-writer {
        start: static func(id: id) -> result<completions-writer, io-error>;
        write: func(value: string) -> result<_, io-error>;
        finish: static func(this: completions-writer, options: option<completion-result-options>) -> result<_, io-error>;
    }
}
