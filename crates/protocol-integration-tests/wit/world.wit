package wasmcp:protocol-integration-tests@0.1.0;

/// Integration test harness for protocol streaming
///
/// This component imports the actual protocol interfaces and provides
/// a mock output implementation that captures messages for validation.

world test-harness {
    // Import the actual protocol we're testing
    import wasmcp:mcp/tools-response@0.3.1-alpha.33;
    import wasmcp:mcp/resources-response@0.3.1-alpha.33;

    // Import the output interface (provided by stdio-transport)
    import wasmcp:mcp/output@0.3.1-alpha.33;

    // Import WASI filesystem to create input-streams for testing
    import wasi:filesystem/types@0.2.3;
    import wasi:filesystem/preopens@0.2.3;

    // Export WASI CLI to make this a runnable test
    export wasi:cli/run@0.2.0;
}
